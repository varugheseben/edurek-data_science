   "source": [
    "# Write a Python program to check whether a number is even or odd.\n",
    "try:\n",
    "\tnumber = int(input(\"Enter a number: \"))\n",
    "\n",
    "\tif number % 2 == 0:\n",
    "\t\tprint(f'{number} is even number')\n",
    "\telse:\n",
    "\t\tprint(f'{number} is odd number')\n",
    "except Exception as e:\n",
    "\tprint(e.args[0])"
   ]
