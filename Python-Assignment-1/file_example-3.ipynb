   "source": [
    "# Write a program to count the number of words in a file.\n",
    "\n",
    "with open(\"data/example.txt\", \"r\") as f:\n",
    "    counter = 0\n",
    "    for line in f:\n",
    "        line = line.strip()\n",
    "        if line != \"\":\n",
    "            counter = counter + len(line.split(\" \"))\n",
    "\n",
    "    print(f'Word count: {counter}');"
   ]
