   "source": [
    "# Write a function to calculate factorial of a number.\n",
    "\n",
    "def factorial(number):\n",
    "    if number == 0:\n",
    "        return 1\n",
    "    else:\n",
    "        return number * factorial(number -1)\n",
    "\n",
    "\n",
    "number = int(input(\"Enter a number: \"))\n",
    "print(f'Factorial of {number} = {factorial(number)}')\n"
   ]
  },
