   "source": [
    "# Write a program to print numbers from 1 to 10 using a while loop.\n",
    "\n",
    "start = 1\n",
    "end = 10\n",
    "\n",
    "while start <= end:\n",
    "    print(start)\n",
    "    start = start + 1"
   ]
